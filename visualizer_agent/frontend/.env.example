# SAGE frontend environment.
# In dev the Vite proxy forwards /api and /ws to localhost:8000, so leave these blank.
# For a split deploy (frontend on Vercel, backend on EC2), point them at the gateway:
#   VITE_API_BASE=https://sage-api.your-domain.com
#   VITE_WS_BASE=wss://sage-api.your-domain.com
VITE_API_BASE=
VITE_WS_BASE=
