# ─────────────────────────────────────────────────────────────────────────────
# SAGE environment variables
# Copy to .env and fill in values before running docker compose up.
#
# Required to run the knowledge base (no Bedrock):
#   FALKORDB_PASSWORD, REDIS_URL, LLM_PROVIDER=stub
#
# Required for full operation with AWS Bedrock:
#   LLM_PROVIDER=bedrock, AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
#
# Required for real sensory data (each is free-tier):
#   AISSTREAM_API_KEY, EIA_API_KEY, NEWSAPI_KEY
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM provider ─────────────────────────────────────────────────────────────
# "stub"    → no LLM calls; synthesis returns placeholder prose (local dev)
# "openai"  → OpenAI GPT-4o (set OPENAI_API_KEY)
# "bedrock" → AWS Bedrock Nova Pro (set AWS_* below)
LLM_PROVIDER=bedrock

# ── OpenAI (if LLM_PROVIDER=openai) ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── AWS Bedrock (if LLM_PROVIDER=bedrock) ─────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── FalkorDB ─────────────────────────────────────────────────────────────────
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
FALKORDB_USERNAME=
FALKORDB_PASSWORD=

# ── Redis ingest queue ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SAGE_INGEST_QUEUE=sage:ingest
SAGE_BATCH_SIZE=10
SAGE_FLUSH_INTERVAL_S=30

# ── Wiki store ────────────────────────────────────────────────────────────────
# WIKI_DIR is unset on host → code defaults to knowledge/wiki (single source).
# Docker overrides it to /app/wiki via docker-compose (bind-mounted to ./knowledge/wiki).

# ── Fusion model ─────────────────────────────────────────────────────────────
FUSION_MODEL_PATH=sensory_agent/fusion_model.pkl
FEEDBACK_LOG_PATH=demo_cache/feedback_log.jsonl

# ── Sensory agent API keys (all free tier) ────────────────────────────────────
# Put REAL keys in .env.local (gitignored), NOT here. These are placeholders.
#   aisstream.io  → free WebSocket AIS  (https://aisstream.io)
#   EIA           → free Open Data key  (https://www.eia.gov/opendata/register.php)
#   newsdata.io   → free news API key   (https://newsdata.io)
AISSTREAM_API_KEY=your_aisstream_key_here
EIA_API_KEY=your_eia_key_here
NEWSDATA_API_KEY=your_newsdata_key_here

# ── Sentiment model (HuggingFace, runs locally) ──────────────────────────────
SENTIMENT_MODEL=tabularisai/multilingual-sentiment-analysis

# ── Sensory agent poll intervals (seconds) ───────────────────────────────────
PRICE_POLL_INTERVAL_S=300
EIA_POLL_INTERVAL_S=3600
NEWS_POLL_INTERVAL_S=900
SANCTIONS_POLL_INTERVAL_S=21600
AIS_CLUSTER_INTERVAL_S=300

# ── Voice interface (System 6 — Gnani conversational voice AI) ────────────────
GNANI_API_KEY=
GNANI_WS_URL=

# ── Demo mode ─────────────────────────────────────────────────────────────────
# DEMO_MODE=true replays demo_cache/ signals instead of hitting live APIs
DEMO_MODE=false

# ── Cost guard ────────────────────────────────────────────────────────────────
CLOUDWATCH_ALARM_THRESHOLD=150
